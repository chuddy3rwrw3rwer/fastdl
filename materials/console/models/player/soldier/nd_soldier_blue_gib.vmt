"VertexLitGeneric"
{
	"$basetexture" "console\models\player\soldier\ND_soldier_blue_gibTF"
	"$bumpmap" "console\models\player\soldier\ND_soldier_body_normal"

	"$phong" "1"
//	"$phongexponenttexture" "models\player\soldier\soldier_exponent"
	"$phongexponent" "23"
	"$phongboost" ".3"	
	"$lightwarptexture" "models/player/pyro/pyro_lightwarp"
	"$phongfresnelranges"	"[.3 1 3]"
	"$halflambert" "1"

	// Rim lighting parameters
	"$rimlight" "1"												// To enable rim lighting (requires phong)
	"$rimlightexponent" "4"										// Exponent for phong component of rim lighting	
	"$rimlightboost" "2"										// Boost for ambient cube component of rim lighting
}
